#!/usr/bin/env node
"use strict";

const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const { spawn, spawnSync } = require("node:child_process");

const ROLE_FIELDS = {
  "quick-bugfix": ["implAgent", "testAgent"],
  "simple-feature": ["planAgent", "implAgent", "validateAgent"],
  "complex-feature-refactor": ["planAgent", "planReviewAgent", "implAgent", "validateAgent"],
};

const FLOW_RUN_LOOKUP_TIMEOUT_MS = 15_000;
const FLOW_RUN_LOOKUP_INTERVAL_MS = 250;

const ENV_AGENT_NAMES = {
  planAgent: ["PLAN_AGENT", "PLANNING_AGENT"],
  planReviewAgent: ["PLAN_REVIEW_AGENT", "PLAN_REVIEWING_AGENT"],
  implAgent: ["IMPLEMENT_AGENT", "IMPLEMENTATION_AGENT", "IMPL_AGENT"],
  validateAgent: ["VALIDATE_AGENT", "VALIDATION_AGENT"],
  testAgent: ["TEST_AGENT"],
  reviewAgent: ["REVIEW_AGENT"],
};

const PROFILE_KEYS = {
  planAgent: "plan",
  planReviewAgent: "planReview",
  implAgent: "impl",
  validateAgent: "validate",
  testAgent: "test",
  reviewAgent: "review",
};

function usage() {
  console.error(`Usage:
  acpx-flow-run <flow|path> [--input-file <path> | --input-json <json>] [--foreground] [--log <path>] [--dry-run] [--output-dir <dir>] -- [acpx flags...]

Defaults:
  Runs in the background and passes --approve-all unless another permission flag is supplied.
  Agent env vars override input role fields: PLAN_AGENT, PLAN_REVIEW_AGENT, IMPLEMENT_AGENT, VALIDATE_AGENT, TEST_AGENT.
  Missing role agents fall back to the flow template AGENT_PROFILES defaults.

Examples:
  scripts/acpx-flow-run simple-feature --input-file flows/examples/simple-feature.input.json
  PLAN_AGENT=aiden PLAN_REVIEW_AGENT=trae IMPLEMENT_AGENT=trae VALIDATE_AGENT=aiden scripts/acpx-flow-run complex-feature-refactor --input-json '{"task":"..."}' --dry-run`);
}

function fail(message) {
  console.error(`ERROR: ${message}`);
  process.exit(1);
}

function parseArgs(argv) {
  const sep = argv.indexOf("--");
  const ownArgs = sep === -1 ? argv : argv.slice(0, sep);
  const acpxArgs = sep === -1 ? [] : argv.slice(sep + 1);
  const flow = ownArgs.shift();
  if (!flow || flow === "-h" || flow === "--help") {
    usage();
    process.exit(flow ? 0 : 1);
  }

  const opts = {
    flow,
    inputFile: null,
    inputJson: null,
    background: true,
    log: null,
    dryRun: false,
    outputDir: null,
    acpxArgs,
  };

  for (let i = 0; i < ownArgs.length; i += 1) {
    const arg = ownArgs[i];
    if (arg === "--input-file") opts.inputFile = ownArgs[++i];
    else if (arg === "--input-json") opts.inputJson = ownArgs[++i];
    else if (arg === "--background") opts.background = true;
    else if (arg === "--foreground") opts.background = false;
    else if (arg === "--log") opts.log = ownArgs[++i];
    else if (arg === "--dry-run") opts.dryRun = true;
    else if (arg === "--output-dir") opts.outputDir = ownArgs[++i];
    else fail(`Unknown option: ${arg}`);
  }

  if (opts.inputFile && opts.inputJson) fail("Use only one of --input-file or --input-json.");
  if (opts.inputFile === undefined || opts.inputJson === undefined || opts.log === undefined || opts.outputDir === undefined) {
    fail("Missing value for option.");
  }
  return opts;
}

function readInput(opts) {
  if (opts.inputJson) return parseJson(opts.inputJson, "--input-json");
  if (opts.inputFile) {
    const filePath = path.resolve(opts.inputFile);
    return parseJson(fs.readFileSync(filePath, "utf8"), opts.inputFile);
  }
  return {};
}

function parseJson(raw, label) {
  try {
    return JSON.parse(raw);
  } catch (error) {
    fail(`${label} must contain valid JSON: ${error.message}`);
  }
}

function resolveFlow(skillRoot, flowArg) {
  const candidatePaths = [];
  if (flowArg.endsWith(".ts") || flowArg.includes("/") || flowArg.includes(path.sep)) {
    candidatePaths.push(path.resolve(flowArg));
    candidatePaths.push(path.resolve(skillRoot, flowArg));
  } else {
    candidatePaths.push(path.join(skillRoot, "flows", `${flowArg}.flow.ts`));
  }

  const flowPath = candidatePaths.find((candidate) => fs.existsSync(candidate));
  if (!flowPath) fail(`Flow not found: ${flowArg}`);
  const flowName = path.basename(flowPath).replace(/\.flow\.ts$/, "");
  if (!ROLE_FIELDS[flowName]) fail(`Unknown flow template: ${flowName}`);
  return { flowName, flowPath };
}

function envAgent(field) {
  for (const name of ENV_AGENT_NAMES[field] || []) {
    if (Object.prototype.hasOwnProperty.call(process.env, name)) {
      return process.env[name];
    }
  }
  return undefined;
}

function normalizeAgent(value, field) {
  if (value === undefined || value === null) {
    fail(`No agent value found for \`${field}\` in env, input JSON, or template defaults.`);
  }
  if (typeof value !== "string" || !value.trim()) {
    fail(`Input field \`${field}\` must be a non-empty string.`);
  }
  return value.trim();
}

function sanitizeInput(input, flowName, defaultProfiles) {
  if (!input || typeof input !== "object" || Array.isArray(input)) {
    fail("Flow input must be a JSON object.");
  }

  const sanitized = { ...input };
  if (!sanitized.validateAgent && typeof sanitized.reviewAgent === "string" && sanitized.reviewAgent.trim()) {
    sanitized.validateAgent = sanitized.reviewAgent;
  }
  for (const field of Object.keys(PROFILE_KEYS)) {
    if (!ROLE_FIELDS[flowName].includes(field)) delete sanitized[field];
  }

  const agents = {};
  for (const field of ROLE_FIELDS[flowName]) {
    const profileKey = PROFILE_KEYS[field];
    const agent = normalizeAgent(envAgent(field) ?? sanitized[field] ?? defaultProfiles[profileKey], field);
    sanitized[field] = agent;
    agents[profileKey] = agent;
  }
  return { sanitized, agents };
}

function readDefaultProfiles(source) {
  const match = source.match(/const AGENT_PROFILES = \{([\s\S]*?)\} as const;/);
  if (!match) fail("Flow template is missing AGENT_PROFILES block.");

  const profiles = {};
  const propertyPattern = /(\w+):\s*"([^"]*)"/g;
  let property;
  while ((property = propertyPattern.exec(match[1])) !== null) {
    profiles[property[1]] = property[2];
  }
  return profiles;
}

function materializeFlow(source, agents) {
  const block = [
    "const AGENT_PROFILES = {",
    ...Object.entries(agents).map(([key, value]) => `  ${key}: ${JSON.stringify(value)},`),
    "} as const;",
  ].join("\n");
  const profileBlockPattern = /const AGENT_PROFILES = \{[\s\S]*?\} as const;/;
  if (!profileBlockPattern.test(source)) fail("Flow template is missing AGENT_PROFILES block.");
  return source.replace(profileBlockPattern, block);
}

function copyFlowSharedFiles(skillRoot, outDir) {
  const sharedDir = path.join(skillRoot, "flows", "shared");
  if (!fs.existsSync(sharedDir)) return;

  const targetDir = path.join(outDir, "shared");
  fs.mkdirSync(targetDir, { recursive: true });
  for (const entry of fs.readdirSync(sharedDir, { withFileTypes: true })) {
    if (!entry.isFile()) continue;
    fs.copyFileSync(path.join(sharedDir, entry.name), path.join(targetDir, entry.name));
  }
}

function writeMaterialized(skillRoot, opts, flowName, source, input, agents) {
  const outDir = opts.outputDir
    ? path.resolve(opts.outputDir)
    : fs.mkdtempSync(path.join(os.tmpdir(), `acpx-flow-${flowName}-`));
  fs.mkdirSync(outDir, { recursive: true });
  copyFlowSharedFiles(skillRoot, outDir);

  const generatedFlow = path.join(outDir, `${flowName}.flow.ts`);
  const generatedInput = path.join(outDir, `${flowName}.input.json`);
  fs.writeFileSync(generatedFlow, materializeFlow(source, agents), "utf8");
  fs.writeFileSync(generatedInput, `${JSON.stringify(input, null, 2)}\n`, "utf8");
  return { outDir, generatedFlow, generatedInput };
}

function flowRunsRoot() {
  return path.join(os.homedir(), ".acpx", "flows", "runs");
}

function sleepMs(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);
}

function readJsonFile(filePath) {
  try {
    return JSON.parse(fs.readFileSync(filePath, "utf8"));
  } catch {
    return null;
  }
}

function isMatchingRunManifest(manifest, flowName, generatedFlow, earliestStartedAtMs) {
  if (!manifest || typeof manifest !== "object") return false;
  if (manifest.flowName !== flowName) return false;
  if (manifest.flowPath !== generatedFlow) return false;

  if (typeof manifest.startedAt === "string") {
    const startedAtMs = Date.parse(manifest.startedAt);
    if (Number.isFinite(startedAtMs) && startedAtMs < earliestStartedAtMs) return false;
  }
  return true;
}

function findFlowRun(flowName, generatedFlow, earliestStartedAtMs) {
  const runsRoot = flowRunsRoot();
  let entries;
  try {
    entries = fs.readdirSync(runsRoot, { withFileTypes: true });
  } catch {
    return null;
  }

  const matches = [];
  for (const entry of entries) {
    if (!entry.isDirectory()) continue;
    const runDir = path.join(runsRoot, entry.name);
    const manifestPath = path.join(runDir, "manifest.json");
    const manifest = readJsonFile(manifestPath);
    if (!isMatchingRunManifest(manifest, flowName, generatedFlow, earliestStartedAtMs)) continue;
    matches.push({ runDir, manifestPath, manifest });
  }

  matches.sort((a, b) => String(b.manifest.startedAt || "").localeCompare(String(a.manifest.startedAt || "")));
  return matches[0] || null;
}

function waitForFlowRun(flowName, generatedFlow, earliestStartedAtMs) {
  const deadline = Date.now() + FLOW_RUN_LOOKUP_TIMEOUT_MS;
  while (Date.now() <= deadline) {
    const match = findFlowRun(flowName, generatedFlow, earliestStartedAtMs);
    if (match) return match;
    sleepMs(FLOW_RUN_LOOKUP_INTERVAL_MS);
  }
  return findFlowRun(flowName, generatedFlow, earliestStartedAtMs);
}

function printFlowRunLookup(flowName, generatedFlow, lookup) {
  if (!lookup) {
    console.log("runLookup=pending");
    console.log(`runSearchRoot=${flowRunsRoot()}`);
    console.log(`runSearchFlow=${generatedFlow}`);
    console.log(`runSearchFlowName=${flowName}`);
    return;
  }

  const runDir = lookup.runDir;
  const runId = lookup.manifest.runId || path.basename(runDir);
  console.log("runLookup=matched");
  console.log(`runId=${runId}`);
  console.log(`runDir=${runDir}`);
  console.log(`manifest=${lookup.manifestPath}`);
  console.log(`live=${path.join(runDir, "projections", "live.json")}`);
  console.log(`runProjection=${path.join(runDir, "projections", "run.json")}`);
  console.log(`steps=${path.join(runDir, "projections", "steps.json")}`);
  console.log(`trace=${path.join(runDir, "trace.ndjson")}`);
  console.log(`sessionsDir=${path.join(runDir, "sessions")}`);
  console.log(`artifactsDir=${path.join(runDir, "artifacts")}`);
}

function runAcpx(opts, flowName, generatedFlow, generatedInput) {
  const acpx = process.env.ACPX_BIN || "acpx";
  const acpxArgs = withDefaultApproveAll(opts.acpxArgs);
  const args = [...acpxArgs, "flow", "run", generatedFlow, "--input-file", generatedInput];

  if (opts.background) {
    const earliestStartedAtMs = Date.now() - 1000;
    const logPath = path.resolve(opts.log || path.join(os.tmpdir(), `acpx-flow-${flowName}.log`));
    const fd = fs.openSync(logPath, "a");
    const child = spawn(acpx, args, {
      detached: true,
      stdio: ["ignore", fd, fd],
    });
    child.unref();
    console.log(`pid=${child.pid}`);
    console.log(`log=${logPath}`);
    console.log(`flow=${generatedFlow}`);
    console.log(`input=${generatedInput}`);
    console.log(`command=${acpx} ${args.join(" ")}`);
    printFlowRunLookup(flowName, generatedFlow, waitForFlowRun(flowName, generatedFlow, earliestStartedAtMs));
    return 0;
  }

  const result = spawnSync(acpx, args, { stdio: "inherit" });
  if (result.error) fail(result.error.message);
  return result.status ?? 1;
}

function withDefaultApproveAll(args) {
  const permissionFlags = new Set([
    "--approve-all",
    "--approve-reads",
    "--deny-all",
    "--non-interactive-permissions",
    "--permission-policy",
    "--policy",
  ]);
  if (args.some((arg) => permissionFlags.has(arg))) return args;
  return ["--approve-all", ...args];
}

function main() {
  const opts = parseArgs(process.argv.slice(2));
  const skillRoot = path.resolve(__dirname, "..");
  const { flowName, flowPath } = resolveFlow(skillRoot, opts.flow);
  const source = fs.readFileSync(flowPath, "utf8");
  const defaultProfiles = readDefaultProfiles(source);
  const input = readInput(opts);
  const { sanitized, agents } = sanitizeInput(input, flowName, defaultProfiles);
  const materialized = writeMaterialized(skillRoot, opts, flowName, source, sanitized, agents);

  if (opts.dryRun) {
    console.log(JSON.stringify({
      flowName,
      agents,
      flow: materialized.generatedFlow,
      input: materialized.generatedInput,
    }, null, 2));
    return;
  }

  process.exit(runAcpx(opts, flowName, materialized.generatedFlow, materialized.generatedInput));
}

main();
