#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
INSPECTOR_CLI="$SKILL_ROOT/acpx-inspector/inspector/dist/cli.js"

if [[ ! -f "$INSPECTOR_CLI" ]]; then
  echo "ERROR: acpx-inspector CLI not found: $INSPECTOR_CLI" >&2
  echo "Run the inspector build in acpx-inspector/inspector, or restore dist/cli.js." >&2
  exit 1
fi

exec node "$INSPECTOR_CLI" "$@"
