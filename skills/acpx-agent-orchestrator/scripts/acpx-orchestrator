#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ -f "$ROOT/dist/cli.mjs" ]]; then
  exec node "$ROOT/dist/cli.mjs" "$@"
fi

if [[ -f "$ROOT/dist/cli.js" ]]; then
  exec node "$ROOT/dist/cli.js" "$@"
fi

if [[ -x "$ROOT/node_modules/.bin/tsx" ]]; then
  exec "$ROOT/node_modules/.bin/tsx" "$ROOT/src/cli.ts" "$@"
fi

cat >&2 <<EOF
acpx-orchestrator is not built and local dependencies are missing.
Run:
  cd "$ROOT"
  npm install
  npm run build
EOF
exit 1
