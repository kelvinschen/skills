#!/usr/bin/env node
"use strict";

const fs = require("node:fs");
const os = require("node:os");
const path = require("node:path");
const { spawnSync } = require("node:child_process");

const TERMINAL_FLOW_STATUSES = new Set(["completed", "failed", "timed_out", "cancelled"]);
const PREVIEW_CHARS = 1000;

function usage(exitCode = 0) {
  const text = `Usage:
  acpx-visualize --flow-run <path|latest> [--output <path>]
  acpx-visualize --session-json <path> [--output <path>]
  acpx-visualize --agent <name> --cwd <dir> --session <name> [--output <path>]

Generates a static HTML audit report with CDN-enhanced Markdown rendering for an ended acpx flow or captured session.
`;
  process.stderr.write(text);
  process.exit(exitCode);
}

function fail(message) {
  process.stderr.write(`${message}\n`);
  process.exit(1);
}

function parseArgs(argv) {
  const flags = {};
  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "-h" || arg === "--help") usage(0);
    if (!arg.startsWith("--")) fail(`Unexpected argument: ${arg}`);
    const key = arg.slice(2);
    const value = argv[i + 1];
    if (value === undefined || value.startsWith("--")) fail(`Missing value for --${key}`);
    flags[key] = value;
    i += 1;
  }
  return flags;
}

function expandHome(input) {
  if (!input) return input;
  if (input === "~") return os.homedir();
  if (input.startsWith("~/")) return path.join(os.homedir(), input.slice(2));
  return input;
}

function readJson(filePath) {
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function maybeReadJson(filePath) {
  if (!fs.existsSync(filePath)) return null;
  return readJson(filePath);
}

function writeFile(filePath, content) {
  fs.mkdirSync(path.dirname(path.resolve(filePath)), { recursive: true });
  fs.writeFileSync(filePath, content, "utf8");
}

function maybeReadText(filePath) {
  try {
    if (!filePath || !fs.existsSync(filePath) || !fs.statSync(filePath).isFile()) return null;
    return fs.readFileSync(filePath, "utf8");
  } catch {
    return null;
  }
}

function safeId(value) {
  return String(value || "audit").replace(/[^A-Za-z0-9._-]+/g, "-").replace(/^-+|-+$/g, "") || "audit";
}

function truncate(value, max = PREVIEW_CHARS) {
  const text = String(value ?? "").trim();
  if (text.length <= max) return text;
  return `${text.slice(0, max)}\n... [truncated ${text.length - max} chars]`;
}

function durationMs(start, end) {
  if (!start || !end) return null;
  const ms = Date.parse(end) - Date.parse(start);
  return Number.isFinite(ms) ? ms : null;
}

function formatDuration(ms) {
  if (!Number.isFinite(ms)) return "-";
  if (ms < 1000) return `${ms}ms`;
  const seconds = Math.round(ms / 100) / 10;
  if (seconds < 60) return `${seconds}s`;
  const minutes = Math.floor(seconds / 60);
  const rest = Math.round(seconds % 60);
  return `${minutes}m ${rest}s`;
}

function stringifyPreview(value) {
  if (value == null) return "";
  if (typeof value === "string") return truncate(value);
  if (typeof value === "number" || typeof value === "boolean") return String(value);
  if (value.Text && typeof value.Text === "string") return truncate(value.Text);
  if (value.output) return stringifyPreview(value.output);
  if (value.Output) return stringifyPreview(value.Output);
  if (value.stdout || value.stderr) {
    return truncate([value.stdout ? `stdout:\n${value.stdout}` : "", value.stderr ? `stderr:\n${value.stderr}` : ""].filter(Boolean).join("\n\n"));
  }
  return truncate(JSON.stringify(value, null, 2));
}

function stringifyFull(value) {
  if (value == null) return "";
  if (typeof value === "string") return value.trim();
  if (typeof value === "number" || typeof value === "boolean") return String(value);
  if (value.Text && typeof value.Text === "string") return value.Text.trim();
  if (value.output) return stringifyFull(value.output);
  if (value.Output) return stringifyFull(value.Output);
  if (value.stdout || value.stderr) {
    return [value.stdout ? `stdout:\n${value.stdout}` : "", value.stderr ? `stderr:\n${value.stderr}` : ""].filter(Boolean).join("\n\n").trim();
  }
  return JSON.stringify(value, null, 2);
}

function unique(values) {
  return Array.from(new Set(values.filter(Boolean)));
}

function collectFlowMemoryCandidates(value, candidates = []) {
  if (!value || typeof value !== "object") return candidates;
  if (Array.isArray(value)) {
    for (const item of value) collectFlowMemoryCandidates(item, candidates);
    return candidates;
  }
  for (const [key, item] of Object.entries(value)) {
    if ((key === "flowMemoryPath" || key === "memoryFile") && typeof item === "string") {
      candidates.push(item);
      continue;
    }
    if (key === "handoffRoot" && typeof item === "string") {
      candidates.push(path.join(item, "flow-memory.md"));
      continue;
    }
    collectFlowMemoryCandidates(item, candidates);
  }
  return candidates;
}

function resolveRepoRoot(cwd) {
  if (!cwd) return null;
  const result = spawnSync("git", ["-C", cwd, "rev-parse", "--show-toplevel"], {
    encoding: "utf8",
    stdio: ["ignore", "pipe", "ignore"],
  });
  if (result.status === 0 && result.stdout.trim()) return result.stdout.trim();
  return cwd;
}

function loadFlowMemory(runProjection, steps) {
  const runId = runProjection.runId;
  const input = runProjection.input && typeof runProjection.input === "object" ? runProjection.input : {};
  const candidates = [
    ...collectFlowMemoryCandidates(runProjection),
    ...collectFlowMemoryCandidates(steps),
  ];
  if (typeof input.handoffDir === "string" && input.handoffDir.trim() && runId) {
    const rawHandoffDir = expandHome(input.handoffDir.trim());
    const base = typeof input.cwd === "string" && input.cwd.trim() ? path.resolve(expandHome(input.cwd.trim())) : process.cwd();
    const handoffDir = path.isAbsolute(rawHandoffDir) ? rawHandoffDir : path.resolve(base, rawHandoffDir);
    candidates.push(path.join(handoffDir, runId, "flow-memory.md"));
  }
  if (typeof input.cwd === "string" && input.cwd.trim() && runId) {
    const cwd = path.resolve(expandHome(input.cwd.trim()));
    const repoRoot = resolveRepoRoot(cwd);
    if (repoRoot) candidates.push(path.join(repoRoot, "tmp", "flow_handoffs", runId, "flow-memory.md"));
  }

  const paths = unique(candidates.map((candidate) => path.resolve(expandHome(candidate))));
  for (const filePath of paths) {
    const content = maybeReadText(filePath);
    if (content != null) {
      return {
        path: filePath,
        exists: true,
        content,
        size: Buffer.byteLength(content, "utf8"),
        candidates: paths,
      };
    }
  }
  return paths.length > 0 ? {
    path: paths[0],
    exists: false,
    content: "",
    size: 0,
    candidates: paths,
  } : null;
}

function parseRawInput(rawInput) {
  if (typeof rawInput !== "string") return rawInput;
  try {
    return JSON.parse(rawInput);
  } catch {
    return rawInput;
  }
}

function extractContentText(content) {
  if (!Array.isArray(content)) return "";
  return content.map((part) => {
    if (typeof part?.Text === "string") return part.Text;
    if (part?.ToolUse?.name) return `[tool:${part.ToolUse.name}]`;
    return "";
  }).filter(Boolean).join("\n");
}

function findToolResult(toolResults, toolUseId) {
  if (!toolResults || typeof toolResults !== "object") return null;
  if (Object.prototype.hasOwnProperty.call(toolResults, toolUseId)) return toolResults[toolUseId];
  return Object.values(toolResults).find((value) => value && value.tool_use_id === toolUseId) || null;
}

function parseSessionRecord(record, options = {}) {
  const binding = options.binding || null;
  const sessionLabel = binding?.handle || record.name || record.acpxRecordId || "session";
  const conversation = [];
  const tools = [];
  let lastAssistantText = "";
  let messageIndex = 0;

  for (const message of Array.isArray(record.messages) ? record.messages : []) {
    messageIndex += 1;
    if (message.User) {
      conversation.push({
        type: "user",
        messageIndex,
        text: extractContentText(message.User.content),
      });
      continue;
    }

    if (!message.Agent) continue;
    const content = Array.isArray(message.Agent.content) ? message.Agent.content : [];
    const toolResults = message.Agent.tool_results || {};
    for (const part of content) {
      if (typeof part?.Text === "string" && part.Text.trim()) {
        lastAssistantText = part.Text;
        conversation.push({
          type: "assistant",
          messageIndex,
          text: part.Text,
        });
        continue;
      }

      if (!part?.ToolUse) continue;
      const toolUse = part.ToolUse;
      const result = findToolResult(toolResults, toolUse.id);
      const input = toolUse.input !== undefined ? toolUse.input : parseRawInput(toolUse.raw_input);
      const tool = {
        sessionLabel,
        messageIndex,
        index: tools.length + 1,
        id: toolUse.id || `tool-${tools.length + 1}`,
        name: toolUse.name || "unknown",
        inputSummary: stringifyPreview(input),
        resultSummary: stringifyPreview(result),
        isError: Boolean(result?.is_error || result?.error || result?.output?.success === false),
      };
      tools.push(tool);
      conversation.push({ type: "tool", messageIndex, tool });
    }
  }

  return {
    label: sessionLabel,
    binding,
    summary: {
      id: record.acpxRecordId || record.acpSessionId || record.name || sessionLabel,
      name: record.name || null,
      agentName: binding?.agentName || null,
      agentCommand: record.agentCommand || binding?.agentCommand || null,
      cwd: record.cwd || binding?.cwd || null,
      createdAt: record.createdAt || null,
      lastUsedAt: record.lastUsedAt || null,
      closed: Boolean(record.closed),
      messageCount: Array.isArray(record.messages) ? record.messages.length : 0,
      toolCount: tools.length,
      lastAssistantText,
    },
    conversation,
    tools,
  };
}

function sessionLookupKeys(session) {
  return [
    session.binding?.bundleId,
    session.binding?.handle,
    session.binding?.name,
    session.binding?.acpxRecordId,
    session.binding?.acpSessionId,
    session.summary?.id,
    session.summary?.name,
    session.label,
  ].filter(Boolean);
}

function stepSessionLookupKeys(step) {
  return [
    step.session?.bundleId,
    step.session?.handle,
    step.session?.name,
    step.session?.acpxRecordId,
    step.session?.acpSessionId,
    step.sessionHandle,
    step.sessionName,
  ].filter(Boolean);
}

function buildSessionLookup(sessions) {
  const lookup = new Map();
  for (const session of sessions) {
    for (const key of sessionLookupKeys(session)) {
      if (!lookup.has(key)) lookup.set(key, session);
    }
  }
  return lookup;
}

function findTimelineSession(step, sessionLookup) {
  for (const key of stepSessionLookupKeys(step)) {
    const session = sessionLookup.get(key);
    if (session) return session;
  }
  return null;
}

function scopedAssistantText(step, session) {
  const conversation = step.trace?.conversation;
  if (!conversation || !session) return "";
  const start = Number(conversation.messageStart);
  const end = Number(conversation.messageEnd);
  if (!Number.isFinite(start) || !Number.isFinite(end)) return "";

  return session.conversation
    .filter((item) => item.type === "assistant" && item.messageIndex > start && item.messageIndex <= end)
    .map((item) => item.text)
    .filter(Boolean)
    .join("\n\n");
}

function resolveStepOutput(step, session) {
  const candidates = [
    ["error", step.error],
    ["rawText", step.rawText],
    ["output", step.output],
    ["trace.outputInline", step.trace?.outputInline],
    ["scopedSessionAssistant", scopedAssistantText(step, session)],
  ];
  for (const [source, value] of candidates) {
    const summary = stringifyFull(value);
    if (summary.trim()) return { summary, source };
  }
  return { summary: "-", source: "none" };
}

function firstString(...values) {
  for (const value of values) {
    if (typeof value === "string" && value.trim()) return value.trim();
  }
  return null;
}

function cwdFromObject(value) {
  if (!value || typeof value !== "object") return null;
  return firstString(value.cwd);
}

function resolveFlowCwd(runProjection, steps, sessions) {
  const outputs = runProjection.outputs && typeof runProjection.outputs === "object" ? runProjection.outputs : {};
  const results = runProjection.results && typeof runProjection.results === "object" ? runProjection.results : {};
  const sessionBindings = runProjection.sessionBindings && typeof runProjection.sessionBindings === "object"
    ? Object.values(runProjection.sessionBindings)
    : [];

  return firstString(
    cwdFromObject(runProjection.input),
    cwdFromObject(outputs.normalize_input),
    cwdFromObject(outputs.summarize),
    cwdFromObject(results.normalize_input?.output),
    cwdFromObject(results.summarize?.output),
    ...steps.flatMap((step) => [
      cwdFromObject(step.output),
      cwdFromObject(step.trace?.outputInline),
      cwdFromObject(step.session),
      cwdFromObject(step.agent),
    ]),
    ...sessionBindings.map(cwdFromObject),
    ...sessions.map((session) => session.summary?.cwd),
  );
}

function resolveLatestFlowRun() {
  const runsDir = path.join(os.homedir(), ".acpx", "flows", "runs");
  if (!fs.existsSync(runsDir)) fail(`No flow runs directory found: ${runsDir}`);
  const candidates = fs.readdirSync(runsDir)
    .map((name) => path.join(runsDir, name))
    .filter((entry) => fs.statSync(entry).isDirectory() && fs.existsSync(path.join(entry, "manifest.json")))
    .map((entry) => ({ entry, mtime: fs.statSync(entry).mtimeMs }))
    .sort((a, b) => b.mtime - a.mtime);
  if (candidates.length === 0) fail(`No flow run bundles found in ${runsDir}`);
  return candidates[0].entry;
}

function loadFlowRun(inputPath) {
  const runDir = inputPath === "latest" ? resolveLatestFlowRun() : path.resolve(expandHome(inputPath));
  const manifest = readJson(path.join(runDir, "manifest.json"));
  const runProjection = readJson(path.join(runDir, "projections", "run.json"));
  const steps = readJson(path.join(runDir, "projections", "steps.json"));
  const status = runProjection.status || manifest.status;
  if (!TERMINAL_FLOW_STATUSES.has(status)) {
    fail(`Flow run is not terminal (${status}). This visualizer only supports ended flows.`);
  }

  const sessions = [];
  const sessionItems = Array.isArray(manifest.sessions) ? manifest.sessions : [];
  for (const item of sessionItems) {
    const binding = maybeReadJson(path.join(runDir, item.bindingPath || ""));
    const record = maybeReadJson(path.join(runDir, item.recordPath || ""));
    if (!record) continue;
    sessions.push(parseSessionRecord(record, { binding }));
  }
  const sessionLookup = buildSessionLookup(sessions);
  const cwd = resolveFlowCwd(runProjection, steps, sessions);

  const timeline = steps.map((step) => {
    const session = findTimelineSession(step, sessionLookup);
    const output = resolveStepOutput(step, session);
    const timelineStep = {
      nodeId: step.nodeId,
      nodeType: step.nodeType,
      outcome: step.outcome,
      startedAt: step.startedAt,
      finishedAt: step.finishedAt,
      durationMs: step.durationMs ?? durationMs(step.startedAt, step.finishedAt),
      agentName: step.agent?.agentName || step.session?.agentName || null,
      sessionHandle: step.session?.handle || null,
      sessionName: step.session?.name || null,
      outputSummary: output.summary,
      outputSource: output.source,
      error: step.error || null,
      traceKeys: Object.keys(step.trace || {}),
    };
    return timelineStep;
  });

  return {
    type: "flow",
    id: runProjection.runId || manifest.runId,
    title: runProjection.runTitle || manifest.runTitle || manifest.flowName,
    status,
    warnings: [],
    summary: {
      flowName: runProjection.flowName || manifest.flowName,
      flowPath: runProjection.flowPath || manifest.flowPath,
      runDir,
      cwd,
      startedAt: runProjection.startedAt || manifest.startedAt,
      finishedAt: runProjection.finishedAt || manifest.finishedAt,
      durationMs: durationMs(runProjection.startedAt || manifest.startedAt, runProjection.finishedAt || manifest.finishedAt),
      stepCount: timeline.length,
      sessionCount: sessions.length,
      toolCount: sessions.reduce((sum, session) => sum + session.tools.length, 0),
    },
    flow: {
      timeline,
    },
    flowMemory: loadFlowMemory(runProjection, steps),
    sessions,
  };
}

function loadSessionJson(filePath) {
  const record = readJson(path.resolve(expandHome(filePath)));
  const session = parseSessionRecord(record);
  const warnings = [];
  if (record.closed !== true) {
    warnings.push("This standalone session is not closed; the audit report represents the captured state only.");
  }
  return {
    type: "session",
    id: record.acpxRecordId || record.acpSessionId || record.name || path.basename(filePath),
    title: record.name || record.acpxRecordId || "ACPX Session Audit",
    status: record.closed ? "closed" : "captured",
    warnings,
    summary: {
      agentCommand: record.agentCommand || null,
      cwd: record.cwd || null,
      createdAt: record.createdAt || null,
      lastUsedAt: record.lastUsedAt || null,
      durationMs: durationMs(record.createdAt, record.lastUsedAt),
      sessionCount: 1,
      toolCount: session.tools.length,
    },
    sessions: [session],
  };
}

function loadAgentSession(flags) {
  const agent = flags.agent;
  const cwd = flags.cwd || process.cwd();
  const session = flags.session;
  if (!agent || !session) fail("--agent and --session are required for agent session mode.");
  const result = spawnSync("acpx", ["--cwd", cwd, "--format", "json", agent, "sessions", "show", session], {
    encoding: "utf8",
    maxBuffer: 50 * 1024 * 1024,
  });
  if (result.status !== 0) fail(result.stderr || result.stdout || `acpx exited with ${result.status}`);
  const tmpPath = `${agent}:${session}`;
  const record = JSON.parse(result.stdout);
  const audit = loadSessionObject(record, tmpPath);
  audit.summary.cwd = cwd;
  return audit;
}

function loadSessionObject(record, label) {
  const session = parseSessionRecord(record);
  const warnings = [];
  if (record.closed !== true) {
    warnings.push("This standalone session is not closed; the audit report represents the captured state only.");
  }
  return {
    type: "session",
    id: record.acpxRecordId || record.acpSessionId || record.name || label,
    title: record.name || record.acpxRecordId || label || "ACPX Session Audit",
    status: record.closed ? "closed" : "captured",
    warnings,
    summary: {
      agentCommand: record.agentCommand || null,
      cwd: record.cwd || null,
      createdAt: record.createdAt || null,
      lastUsedAt: record.lastUsedAt || null,
      durationMs: durationMs(record.createdAt, record.lastUsedAt),
      sessionCount: 1,
      toolCount: session.tools.length,
    },
    sessions: [session],
  };
}

function loadAudit(flags) {
  const modes = [flags["flow-run"], flags["session-json"], flags.agent || flags.session].filter(Boolean).length;
  if (modes !== 1) fail("Choose exactly one input mode: --flow-run, --session-json, or --agent/--session.");
  if (flags["flow-run"]) return loadFlowRun(flags["flow-run"]);
  if (flags["session-json"]) return loadSessionJson(flags["session-json"]);
  return loadAgentSession(flags);
}

function esc(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function jsonScriptValue(value) {
  return JSON.stringify(String(value ?? ""))
    .replace(/</g, "\\u003c")
    .replace(/>/g, "\\u003e")
    .replace(/&/g, "\\u0026");
}

function badge(value) {
  const normalized = String(value || "unknown").toLowerCase();
  return `<span class="badge badge-${esc(normalized)}">${esc(value || "unknown")}</span>`;
}

function outcomeIcon(value) {
  const normalized = String(value || "unknown").toLowerCase();
  if (normalized === "ok" || normalized === "completed" || normalized === "closed" || normalized === "pass") return "🟢";
  if (normalized === "failed" || normalized === "error" || normalized === "timed_out" || normalized === "cancelled" || normalized === "fix") return "🔴";
  if (normalized === "running") return "🔵";
  return "⚪";
}

function previewLines(value, maxLines = 5) {
  const text = String(value ?? "");
  const lines = text.split(/\r?\n/);
  if (lines.length <= maxLines) {
    return { preview: text, full: text, truncated: false };
  }
  return {
    preview: `${lines.slice(0, maxLines).join("\n")}\n... [${lines.length - maxLines} more lines]`,
    full: text,
    truncated: true,
  };
}

function renderSummary(audit) {
  const s = audit.summary || {};
  const rows = [
    ["Type", audit.type],
    ["Status", audit.status],
    ["ID", audit.id],
    ["Title", audit.title],
    ["Started", s.startedAt || s.createdAt || "-"],
    ["Finished", s.finishedAt || s.lastUsedAt || "-"],
    ["Duration", formatDuration(s.durationMs)],
    ["CWD", s.cwd || "-"],
    ["Sessions", s.sessionCount ?? audit.sessions.length],
    ["Tools", s.toolCount ?? 0],
  ];
  return rows.map(([key, value]) => `<div class="kv"><div>${esc(key)}</div><strong>${esc(value)}</strong></div>`).join("");
}

function renderFlowOverview(timeline) {
  if (!timeline.length) return `<p class="muted">No timeline steps were recorded.</p>`;
  return `
    <div class="flow-overview" aria-label="Flow node order">
      ${timeline.map((step, index) => `
        <div class="flow-overview-item">
          <div class="flow-node" title="${esc(`${step.nodeId || "-"} ${step.outcome || "unknown"}`)}">
            <strong>${esc(step.nodeId || "-")}</strong>
            <small>${esc(step.nodeType || "-")}</small>
            <span class="status-dot" aria-label="${esc(step.outcome || "unknown")}">${outcomeIcon(step.outcome)}</span>
          </div>
          ${index < timeline.length - 1 ? `<div class="flow-arrow">→</div>` : ""}
        </div>
      `).join("")}
    </div>
  `;
}

function renderTimeline(audit) {
  if (audit.type !== "flow") return "";
  const rows = audit.flow.timeline.map((step) => {
    const output = previewLines(step.outputSummary || "-");
    return `
    <tr class="searchable" data-search="${esc([step.nodeId, step.nodeType, step.outcome, step.agentName, step.sessionHandle, step.error, step.outputSummary, step.outputSource].join(" "))}">
      <td>${esc(step.nodeId)}</td>
      <td>${esc(step.nodeType)}</td>
      <td class="outcome-cell" title="${esc(step.outcome || "unknown")}">${outcomeIcon(step.outcome)}</td>
      <td>${esc(step.agentName || "-")}</td>
      <td>${esc(step.sessionHandle || "-")}</td>
      <td>${esc(formatDuration(step.durationMs))}</td>
      <td>
        <div class="output-source">
          source: ${esc(step.outputSource || "unknown")}
          ${output.truncated ? `<button type="button" class="output-toggle">Expand</button>` : ""}
        </div>
        <pre class="output-preview">${esc(output.preview)}</pre>
        ${output.truncated ? `<pre class="output-full hidden">${esc(output.full)}</pre>` : ""}
      </td>
    </tr>
  `;
  }).join("");
  return `
    <section>
      <h2>Flow Timeline</h2>
      <h3>Flow Overview</h3>
      ${renderFlowOverview(audit.flow.timeline)}
      <div class="table-wrap">
        <table>
          <thead><tr><th>Node</th><th>Type</th><th>Outcome</th><th>Agent</th><th>Session</th><th>Duration</th><th>Output / Error</th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    </section>
  `;
}

function renderFlowMemory(audit) {
  if (audit.type !== "flow") return "";
  const memory = audit.flowMemory;
  if (!memory) {
    return `
      <section>
        <h2>Shared Flow Memory</h2>
        <p class="muted">No flow memory path was found in this run bundle.</p>
      </section>
    `;
  }
  const candidates = memory.candidates?.length > 1
    ? `<details><summary>Candidate paths</summary><pre>${esc(memory.candidates.join("\n"))}</pre></details>`
    : "";
  const content = memory.exists
    ? `
      <div id="flow-memory-rendered" class="markdown-body"></div>
      <script type="application/json" id="flow-memory-source">${jsonScriptValue(memory.content || "(empty)")}</script>
    `
    : `<p class="warning">Shared flow memory file was referenced but not found.</p>`;
  return `
    <section class="searchable" data-search="${esc([memory.path, memory.content].join(" "))}">
      <h2>Shared Flow Memory</h2>
      <div class="session-meta">
        <span>Path: <strong>${esc(memory.path || "-")}</strong></span>
        <span>Size: <strong>${esc(memory.size || 0)} bytes</strong></span>
      </div>
      ${content}
      ${candidates}
    </section>
  `;
}

function renderConversationItem(item) {
  if (item.type === "user" || item.type === "assistant") {
    const fullText = item.text || "";
    return `
      <article class="message message-${esc(item.type)} searchable" data-search="${esc(truncate(fullText))}">
        <div class="message-title">${esc(item.type)}</div>
        <pre>${esc(fullText)}</pre>
      </article>
    `;
  }
  if (item.type === "tool") {
    const tool = item.tool;
    return `
      <article class="message message-tool searchable" data-search="${esc([tool.name, tool.inputSummary, tool.resultSummary, tool.isError ? "error" : ""].join(" "))}">
        <div class="message-title">tool: ${esc(tool.name)} ${tool.isError ? badge("error") : badge("ok")}</div>
        <div class="tool-grid">
          <div>
            <h3>Input</h3>
            <pre>${esc(tool.inputSummary || "-")}</pre>
          </div>
          <div>
            <h3>Result</h3>
            <pre>${esc(tool.resultSummary || "-")}</pre>
          </div>
        </div>
      </article>
    `;
  }
  return "";
}

function renderSessions(audit) {
  return audit.sessions.map((session, index) => {
    const s = session.summary;
    return `
      <section class="session searchable" data-search="${esc([session.label, s.agentName, s.agentCommand, s.cwd].join(" "))}">
        <h2>${esc(session.label)}</h2>
        <div class="session-meta">
          <span>Agent: <strong>${esc(s.agentName || s.agentCommand || "-")}</strong></span>
          <span>CWD: <strong>${esc(s.cwd || "-")}</strong></span>
          <span>Messages: <strong>${esc(s.messageCount)}</strong></span>
          <span>Tools: <strong>${esc(s.toolCount)}</strong></span>
        </div>
        <details ${index === 0 ? "open" : ""}>
          <summary>Conversation</summary>
          <div class="conversation">${session.conversation.map(renderConversationItem).join("")}</div>
        </details>
      </section>
    `;
  }).join("");
}

function renderHtml(audit) {
  const warnings = (audit.warnings || []).map((warning) => `<div class="warning">${esc(warning)}</div>`).join("");
  return `<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ACPX Audit - ${esc(audit.title || audit.id)}</title>
  <style>
    :root { color-scheme: light; --bg:#f7f7f4; --panel:#ffffff; --line:#deded7; --text:#20201d; --muted:#676761; --ok:#176b3a; --bad:#a13232; --warn:#93630b; --accent:#315b7d; }
    * { box-sizing: border-box; }
    body { margin: 0; font: 14px/1.5 ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: var(--bg); color: var(--text); }
    header { padding: 28px max(22px, calc((100vw - 1180px) / 2)); background: #242520; color: #fff; }
    header h1 { margin: 0 0 10px; font-size: 28px; }
    header p { margin: 0; color: #d7d7ce; }
    main { width: min(1180px, calc(100% - 32px)); margin: 22px auto 56px; }
    section, .summary { background: var(--panel); border: 1px solid var(--line); border-radius: 8px; margin: 16px 0; padding: 18px; box-shadow: 0 10px 28px rgba(0,0,0,.04); }
    h2 { margin: 0 0 14px; font-size: 20px; }
    h3 { margin: 16px 0 10px; color: var(--muted); font-size: 13px; text-transform: uppercase; letter-spacing: .04em; }
    .summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 10px; }
    .kv { border: 1px solid var(--line); border-radius: 6px; padding: 10px; min-width: 0; }
    .kv div { color: var(--muted); font-size: 12px; }
    .kv strong { display: block; overflow-wrap: anywhere; }
    .toolbar { display: flex; gap: 12px; align-items: center; margin: 18px 0; }
    input[type="search"] { width: min(520px, 100%); padding: 10px 12px; border: 1px solid var(--line); border-radius: 6px; font: inherit; }
    .warning { background: #fff6dc; border: 1px solid #e0c16c; color: #6b4a00; border-radius: 6px; padding: 10px 12px; margin: 12px 0; }
    .muted { color: var(--muted); margin: 0; }
    .flow-overview { display: flex; flex-wrap: nowrap; gap: 6px; align-items: center; margin-bottom: 16px; overflow-x: auto; padding-bottom: 4px; }
    .flow-overview-item { display: flex; align-items: center; gap: 6px; flex: 0 0 auto; }
    .flow-node { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; width: 106px; min-height: 58px; border: 1px solid var(--line); border-radius: 6px; padding: 5px; background: #fbfbf8; text-align: center; }
    .flow-node strong { width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 11px; }
    .flow-node small { width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--muted); font-size: 10px; }
    .status-dot { line-height: 1; font-size: 12px; }
    .flow-arrow { color: var(--muted); font-size: 12px; font-weight: 800; }
    .outcome-cell { font-size: 14px; text-align: center; white-space: nowrap; }
    .output-source { color: var(--muted); font-size: 11px; margin-bottom: 5px; text-transform: uppercase; letter-spacing: .04em; }
    .output-toggle { margin-left: 8px; border: 1px solid var(--line); border-radius: 5px; background: #fff; color: var(--accent); cursor: pointer; font: inherit; font-size: 11px; padding: 1px 6px; text-transform: none; letter-spacing: 0; }
    .table-wrap { overflow: auto; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid var(--line); padding: 9px; text-align: left; vertical-align: top; }
    th { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: .04em; }
    pre { white-space: pre-wrap; overflow-wrap: anywhere; margin: 0; font: 12px/1.45 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; }
    details { margin-top: 12px; }
    summary { cursor: pointer; color: var(--accent); font-weight: 650; }
    .badge { display: inline-block; border-radius: 999px; padding: 2px 8px; font-size: 12px; font-weight: 700; background: #e7e7e0; color: #333; }
    .badge-ok, .badge-completed, .badge-closed { background: #dff2e6; color: var(--ok); }
    .badge-error, .badge-failed, .badge-timed_out, .badge-cancelled { background: #f6dddd; color: var(--bad); }
    .message { border: 1px solid var(--line); border-radius: 7px; padding: 12px; margin: 10px 0; }
    .message-title { color: var(--muted); font-weight: 800; text-transform: uppercase; font-size: 12px; margin-bottom: 8px; }
    .message-user { background: #f8fafc; }
    .message-assistant { background: #fbfbf8; }
    .message-tool { background: #f5f7fb; border-color: #cfd8e6; }
    .message-result { background: #f8f6ef; }
    .tool-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; }
    .tool-grid h3 { margin: 0 0 6px; color: var(--muted); font-size: 12px; text-transform: uppercase; }
    .session-meta { display: flex; flex-wrap: wrap; gap: 12px; color: var(--muted); margin-bottom: 10px; }
    .markdown-body { border: 1px solid var(--line); border-radius: 7px; padding: 14px; margin: 12px 0; background: #fff; overflow-wrap: anywhere; }
    .markdown-body h1, .markdown-body h2, .markdown-body h3 { color: var(--text); text-transform: none; letter-spacing: 0; margin: 16px 0 8px; }
    .markdown-body h1 { font-size: 22px; }
    .markdown-body h2 { font-size: 18px; }
    .markdown-body h3 { font-size: 15px; }
    .markdown-body p, .markdown-body ul, .markdown-body ol, .markdown-body pre, .markdown-body blockquote { margin: 8px 0; }
    .markdown-body code { background: #f0f0eb; border-radius: 4px; padding: 1px 4px; }
    .markdown-body pre { background: #f6f6f1; border: 1px solid var(--line); border-radius: 6px; padding: 10px; overflow: auto; }
    .markdown-body blockquote { border-left: 4px solid var(--line); padding-left: 10px; color: var(--muted); }
    .hidden { display: none !important; }
    footer { color: var(--muted); padding: 20px 0; text-align: center; }
  </style>
</head>
<body>
  <header>
    <h1>ACPX Audit Report</h1>
    <p>This local report may contain prompts, paths, commands, command output, and file contents.</p>
  </header>
  <main>
    ${warnings}
    <section>
      <h2>Summary</h2>
      <div class="summary">${renderSummary(audit)}</div>
    </section>
    <div class="toolbar">
      <input id="filter" type="search" placeholder="Filter by node, agent, tool, path, output, or error..." />
      <span id="match-count"></span>
    </div>
    ${renderTimeline(audit)}
    ${renderFlowMemory(audit)}
    ${renderSessions(audit)}
  </main>
  <footer>Generated by acpx-visualize</footer>
  <script src="https://cdn.jsdelivr.net/npm/markdown-it@14.1.0/dist/markdown-it.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.4/dist/purify.min.js"></script>
  <script>
    (function renderFlowMemoryMarkdown() {
      const source = document.getElementById('flow-memory-source');
      const rendered = document.getElementById('flow-memory-rendered');
      if (!source || !rendered || !window.markdownit || !window.DOMPurify) return;
      try {
        const markdown = JSON.parse(source.textContent || '""');
        const md = window.markdownit({ html: false, linkify: true, typographer: true });
        rendered.innerHTML = window.DOMPurify.sanitize(md.render(markdown));
      } catch {
        rendered.textContent = 'Unable to render shared flow memory Markdown.';
      }
    })();

    document.querySelectorAll('.output-toggle').forEach((button) => {
      button.addEventListener('click', () => {
        const cell = button.closest('td');
        const preview = cell?.querySelector('.output-preview');
        const full = cell?.querySelector('.output-full');
        if (!preview || !full) return;
        const expanded = full.classList.toggle('hidden') === false;
        preview.classList.toggle('hidden', expanded);
        button.textContent = expanded ? 'Collapse' : 'Expand';
      });
    });

    const input = document.getElementById('filter');
    const count = document.getElementById('match-count');
    const items = Array.from(document.querySelectorAll('.searchable'));
    function applyFilter() {
      const q = input.value.trim().toLowerCase();
      let shown = 0;
      for (const item of items) {
        const match = !q || (item.dataset.search || '').toLowerCase().includes(q);
        item.classList.toggle('hidden', !match);
        if (match) shown += 1;
      }
      count.textContent = q ? shown + ' matches' : '';
    }
    input.addEventListener('input', applyFilter);
  </script>
</body>
</html>`;
}

function defaultOutputPath(audit) {
  return path.resolve(process.cwd(), `acpx-audit-${safeId(audit.id)}.html`);
}

function main() {
  const flags = parseArgs(process.argv.slice(2));
  const audit = loadAudit(flags);
  const output = path.resolve(expandHome(flags.output || defaultOutputPath(audit)));
  writeFile(output, renderHtml(audit));
  process.stdout.write(`${output}\n`);
}

main();
