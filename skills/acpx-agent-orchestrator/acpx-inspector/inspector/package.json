{
  "name": "acpx-inspector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "acpx-inspector": "dist/cli.js"
  },
  "scripts": {
    "build": "tsdown src/cli.ts src/index.ts --format esm --dts --clean --platform node --target node22 --no-fixedExtension",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "e2e": "tsx --test e2e/acpx-real.test.ts",
    "e2e:agents": "tsx --test e2e/agents-smoke.test.ts",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@10.33.2"
}
