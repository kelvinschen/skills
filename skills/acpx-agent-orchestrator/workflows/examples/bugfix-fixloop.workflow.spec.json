{
  "schemaVersion": "acpx-orchestrator.workflow/v1",
  "name": "bugfix-fixloop",
  "description": "Bugfix workflow with a bounded validation/fix loop.",
  "root": "plan",
  "inputs": {
    "task": { "type": "string", "default": "" },
    "cwd": { "type": "path", "default": "." }
  },
  "roles": {
    "planner": { "category": "planning", "agent": "claude", "mode": "readOnly" },
    "implementer": { "category": "implementation", "agent": "trae", "mode": "edit" },
    "validator": { "category": "validation", "agent": "aiden", "mode": "readOnly" },
    "summarizer": { "category": "summarization", "agent": "claude", "mode": "readOnly" }
  },
  "limits": {
    "maxAgents": 12,
    "maxConcurrency": 2,
    "maxFanoutItems": 4,
    "maxFixRounds": 2,
    "stageTimeoutMinutes": 60
  },
  "stages": [
    {
      "id": "plan",
      "kind": "agentTask",
      "role": "planner",
      "variables": [
        { "name": "task", "source": "input.task" }
      ],
      "prompt": "Plan the smallest safe bugfix for this task:\n\n${task}"
    },
    {
      "id": "implement",
      "kind": "agentTask",
      "role": "implementer",
      "dependsOn": ["plan"],
      "variables": [
        { "name": "task", "source": "input.task" },
        { "name": "plan", "source": "outputs.plan.summary" }
      ],
      "prompt": "Implement the bugfix.\n\nTask:\n${task}\n\nPlan:\n${plan}"
    },
    {
      "id": "quality_loop",
      "kind": "fixLoop",
      "dependsOn": ["implement"],
      "maxRounds": 2,
      "validator": {
        "role": "validator",
        "variables": [
          { "name": "task", "source": "input.task" },
          { "name": "implementation", "source": "outputs.implement.summary" }
        ],
        "prompt": "Validate the bugfix.\n\nTask:\n${task}\n\nImplementation:\n${implementation}"
      },
      "fixer": {
        "role": "implementer",
        "variables": [
          { "name": "findings", "source": "loop.latestFindings", "transform": [{ "fn": "json" }] }
        ],
        "prompt": "Fix only these blocking findings:\n\n${findings}"
      },
      "routingPolicy": {
        "fixOn": ["P0", "P1", "failedRequiredCheck"],
        "ignoreForRouting": ["P2", "P3"],
        "unknown": "blocked"
      },
      "onUnknown": "blocked",
      "onExhausted": "blocked"
    },
    {
      "id": "summarize",
      "kind": "summarize",
      "role": "summarizer",
      "dependsOn": ["quality_loop"],
      "variables": [
        { "name": "task", "source": "input.task" },
        { "name": "quality", "source": "outputs.quality_loop.summary" }
      ],
      "prompt": "Summarize the bugfix workflow outcome.\n\nTask:\n${task}\n\nQuality loop:\n${quality}"
    }
  ]
}
