{
  "schemaVersion": "acpx-orchestrator.workflow/v1",
  "name": "simple-feature",
  "description": "Plan, implement, validate, and summarize a scoped feature change.",
  "root": "plan",
  "inputs": {
    "task": { "type": "string", "default": "" },
    "cwd": { "type": "path", "default": "." },
    "testHints": { "type": "string", "default": "" }
  },
  "roles": {
    "planner": { "category": "planning", "agent": "claude", "mode": "readOnly" },
    "implementer": { "category": "implementation", "agent": "trae", "mode": "edit" },
    "validator": { "category": "validation", "agent": "aiden", "mode": "readOnly" },
    "summarizer": { "category": "summarization", "agent": "claude", "mode": "readOnly" }
  },
  "limits": {
    "maxAgents": 8,
    "maxConcurrency": 2,
    "maxFanoutItems": 4,
    "maxFixRounds": 1,
    "stageTimeoutMinutes": 60,
    "maxOutputChars": 12000
  },
  "stages": [
    {
      "id": "plan",
      "kind": "agentTask",
      "role": "planner",
      "variables": [
        { "name": "task", "source": "input.task" },
        { "name": "cwd", "source": "input.cwd" }
      ],
      "prompt": "Create a concise implementation plan for this task in ${cwd}:\n\n${task}"
    },
    {
      "id": "implement",
      "kind": "agentTask",
      "role": "implementer",
      "dependsOn": ["plan"],
      "variables": [
        { "name": "task", "source": "input.task" },
        { "name": "plan", "source": "outputs.plan.summary" }
      ],
      "prompt": "Implement the requested change.\n\nTask:\n${task}\n\nAccepted plan:\n${plan}"
    },
    {
      "id": "validate",
      "kind": "agentTask",
      "role": "validator",
      "dependsOn": ["implement"],
      "variables": [
        { "name": "task", "source": "input.task" },
        { "name": "implementation", "source": "outputs.implement.summary" },
        { "name": "testHints", "source": "input.testHints", "transform": [{ "fn": "default", "args": { "value": "(none)" } }] }
      ],
      "prompt": "Validate the implementation for task relevance and correctness.\n\nTask:\n${task}\n\nImplementation summary:\n${implementation}\n\nTest hints:\n${testHints}"
    },
    {
      "id": "summarize",
      "kind": "summarize",
      "role": "summarizer",
      "dependsOn": ["validate"],
      "variables": [
        { "name": "task", "source": "input.task" },
        { "name": "validation", "source": "outputs.validate.summary" }
      ],
      "prompt": "Summarize the workflow outcome for the user.\n\nTask:\n${task}\n\nValidation:\n${validation}"
    }
  ]
}
